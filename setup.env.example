# Скопируйте в setup.env и заполните значения.

# Базовые параметры
REPO_DIR=
OPEN_UFW=ask

# Домены
DOMAIN=example.com
DOMAIN_WWW=www.example.com

# SSH hardening (опционально, по умолчанию отключен в stage=all)
ENABLE_SSH_HARDENING=no
SSH_NEW_USER=
SSH_PORT=2222
SSH_PUBLIC_KEY=
SSH_DISABLE_ROOT_LOGIN=yes
SSH_DISABLE_PASSWORD_AUTH=yes

# Docker
DOCKER_REMOVE_CONFLICTING=no
DOCKER_ADD_USER_TO_GROUP=no
DOCKER_GROUP_USER=

# 3x-ui
XUI_DIR=
XUI_IMAGE=ghcr.io/mhsanaei/3x-ui:latest
XUI_CONTAINER_NAME=3xui_app
XUI_HOSTNAME=example.com
XUI_DB_DIR=./db
XUI_CERT_DIR=./cert

# Nginx
NGINX_REPO_CONF=
NGINX_SITE_CONF=/etc/nginx/sites-available/default
NGINX_SITE_ENABLED=/etc/nginx/sites-enabled/default
NGINX_DEPLOY_MODE=symlink
NGINX_PANEL_LISTEN=127.0.0.1:8443
NGINX_PANEL_UPSTREAM=127.0.0.1:20530
PANEL_PATH=/3x-secret

# Certbot
CERTBOT_EMAIL=admin@example.com
CERTBOT_MODE=nginx
CERTBOT_STAGING=no
CERTBOT_NON_INTERACTIVE=no

# Deploy-hook: копирование сертификата в 3x-ui
HOOK_SCRIPT_REPO_PATH=
HOOK_INSTALL_MODE=symlink
HOOK_ENV_FILE=/etc/default/cert-copy-to-3xui
HOOK_CERT_DST=
